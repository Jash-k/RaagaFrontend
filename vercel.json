{
  "framework": "nextjs",
  "rewrites": [
    { "source": "/api/jiosaavn/:path*", "destination": "https://saavn.dev/api/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
